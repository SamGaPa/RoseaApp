@{
    ViewData["Title"] = "Nosotros";
}
<link rel="stylesheet" href="~/css/rosea.css" />
<div class="about-container">

    <section class="about-hero">
        <h1>Sobre Rosea</h1>
        <p>Cuidado personal con calidad, innovación y compromiso.</p>
    </section>

    <section class="about-section">
        <h2>Misión</h2>
        <p>
            Brindar productos de cuidado personal de alta calidad que
            mejoren el bienestar de nuestros clientes, combinando
            innovación, seguridad y precios accesibles.
        </p>
    </section>

    <section class="about-section">
        <h2>Visión</h2>
        <p>
            Ser una empresa líder en el sector de productos de cuidado personal
            en México, reconocida por su excelencia, confianza y compromiso con el cliente.
        </p>
    </section>

    <section class="about-section">
        <h2>Valores</h2>

        <div class="valores-grid">
            <div class="valor-card">
                <h3>Calidad</h3>
                <p>Seleccionamos los mejores productos para garantizar satisfacción.</p>
            </div>

            <div class="valor-card">
                <h3>Compromiso</h3>
                <p>Nos enfocamos en brindar el mejor servicio a nuestros clientes.</p>
            </div>

            <div class="valor-card">
                <h3>Innovación</h3>
                <p>Buscamos constantemente mejorar nuestros procesos y catálogo.</p>
            </div>

            <div class="valor-card">
                <h3>Responsabilidad</h3>
                <p>Actuamos con ética y respeto hacia nuestros clientes y colaboradores.</p>
            </div>
        </div>
    </section>

</div>
