@{
    ViewData["Title"] = "Registro";
}


<h2>Register</h2>

<div class="form-group">
    <input id="nombre" class="form-control" placeholder="Nombre" />
</div>

<div class="form-group">
    <input id="email" class="form-control" placeholder="Email" />
</div>

<div class="form-group">
    <input id="password" type="password" class="form-control" placeholder="Password" />
</div>

<button id="btnRegister" class="btn btn-primary">Register</button>

<div id="msg"></div>

<div class="mb-3 text-center">
    <div class="g-recaptcha"
         data-sitekey="6LfqqWcsAAAAAEFcOix556xAlCUwA45WtHiOJekb"></div>
</div>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>



<script type="module" src="~/js/account/register.main.js"></script>




