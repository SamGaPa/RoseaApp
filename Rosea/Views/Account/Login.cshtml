@model Rosea.Models.LoginViewModel

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="auth-page">

    <div class="auth-card card shadow-lg border-0">

        <div class="card-body p-4">

            <h2 class="text-center brand-title">
                🌸 Rosea
            </h2>

            <p class="text-center text-muted mb-4">
                Inicia sesión en tu cuenta
            </p>

            <form id="loginForm">

                <!-- EMAIL -->
                <input id="email"
                       class="form-control"
                       placeholder="correo@ejemplo.com" />

                <!-- PASSWORD -->
                <input id="password"
                       type="password"
                       class="form-control"
                       placeholder="********" />

                <button type="submit"
                        class="btn btn-rose btn-lg">
                    Iniciar Sesión
                </button>

                <!-- recaptcha -->
  
                <div class="mb-3 text-center">
                    <div class="g-recaptcha"
                         data-sitekey="6LfqqWcsAAAAAEFcOix556xAlCUwA45WtHiOJekb"></div>
                </div>

            </form>

            <!-- MFA -->
            <div id="mfaSection" style="display:none">

                <hr />

                <h5 class="text-center">Verificación de seguridad</h5>

                <p class="text-center text-muted">
                    Ingrese el código de Google Authenticator
                </p>

                <input id="mfaCode"
                       class="form-control text-center"
                       placeholder="123456" />

                <div class="d-grid mt-3">

                    <button id="btnVerifyMfa"
                            type="button"
                            class="btn btn-rose">

                        Verificar código

                    </button>

                </div>

            </div>

            <!-- links -->
            <div class="text-center mt-4">

                <a href="#" class="text-rose d-block mb-2">
                    ¿Olvidaste tu contraseña?
                </a>

                <span class="text-muted">
                    ¿No tienes cuenta?
                </span>

                <a asp-controller="Account"
                   asp-action="Register"
                   class="text-rose">

                    Regístrate

                </a>

            </div>

        </div>

    </div>

</div>


<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script type="module" src="~/js/accountAuth/main.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
          const pwd = document.querySelector("#password");
  const warning = document.getElementById("capsWarning");
  if (!pwd || !warning) return;

  pwd.addEventListener("keyup", function (e) {
    if (typeof e.getModifierState === "function") {
      const caps = e.getModifierState("CapsLock");
      warning.classList.toggle("d-none", !caps);
    } else {
      // Fallback for environments without getModifierState: hide warning
      warning.classList.add("d-none");
    }
  });
});
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


