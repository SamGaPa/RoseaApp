@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="container py-5">

    <h2 class="fw-bold text-rose mb-4">
        🌸 Panel de Administración
    </h2>

    <p class="text-muted mb-5">
        Bienvenido al panel de control de <strong>Rosea Skincare</strong>.
        Aquí puedes administrar productos y revisar los pedidos de la tienda.
    </p>

    <div class="row g-4">

        <!-- ADMIN PRODUCTOS -->
        <div class="col-md-6">
            <div class="card admin-card shadow border-0 h-100">

                <div class="card-body text-center p-5">

                    <i class="bi bi-box-seam fs-1 text-rose mb-3"></i>

                    <h5 class="fw-bold">
                        Administrar Productos
                    </h5>

                    <p class="text-muted">
                        Crear, editar o eliminar productos del catálogo.
                    </p>

                    <a asp-controller="AdminProductos"
                       asp-action="Index"
                       class="btn btn-rose">
                        Ir a productos
                    </a>

                </div>

            </div>
        </div>


        <!-- ADMIN PEDIDOS -->
        <div class="col-md-6">
            <div class="card admin-card shadow border-0 h-100">

                <div class="card-body text-center p-5">

                    <i class="bi bi-bag-heart fs-1 text-rose mb-3"></i>

                    <h5 class="fw-bold">
                        Administrar Pedidos
                    </h5>

                    <p class="text-muted">
                        Ver pedidos realizados por los clientes.
                    </p>

                    <a asp-controller="AdminPedidos"
                       asp-action="Index"
                       class="btn btn-rose">
                        Ver pedidos
                    </a>

                </div>

            </div>
        </div>

    </div>

</div>