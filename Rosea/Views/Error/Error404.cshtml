@{
    ViewData["Title"] = "Página no encontrada";
}

<div class="container-fluid d-flex justify-content-center align-items-center"
     style="min-height:80vh; background-color:#fff0f5;">

    <div class="text-center p-5">

        <h1 class="display-4 fw-bold" style="color:#d63384;">
            404
        </h1>

        <h3 class="mb-3" style="color:#d63384;">
            🌸 Página no encontrada
        </h3>

        <p class="text-muted mb-4">
            Lo sentimos, la página que buscas no existe o fue movida.
        </p>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-lg"
           style="background-color:#d63384; color:white; border-radius:25px;">
            Volver al inicio
        </a>

    </div>
</div>
